# =========================================
# Database Configuration
# =========================================
PGPORT=5432
PGUSER=agentlabs
PGPASSWORD=agentlabs_pass
PGDATABASE=agentlabs

# Internal URL for Docker (use 'db' as hostname)
DATABASE_URL=postgresql://agentlabs:agentlabs_pass@db:5432/agentlabs

# =========================================
# Application Configuration
# =========================================
NODE_ENV=production
PORT=5000
APP_PORT=5000
APP_URL=http://localhost:5000
APP_DOMAIN=localhost
BASE_URL=http://localhost:5000
LOG_LEVEL=info

# =========================================
# Security Secrets
# =========================================
SESSION_SECRET=WILL_BE_AUTO_GENERATED_BY_SETUP
JWT_SECRET=WILL_BE_AUTO_GENERATED_BY_SETUP
